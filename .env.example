# 使用说明：
# 1. 复制本文件为 .env：copy .env.example .env
# 2. 修改 .env 里的值为你真实的数据库连接信息
# 3. 环境变量优先级高于 .env 文件

# Oracle connection settings
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=localhost:1521/ORCLPDB1

# Optional Oracle settings
# ORACLE_THICK_MODE=1
# ORACLE_LIB_DIR=C:\Users\ASUS\Desktop\instantclient_19_28
# ORACLE_CONFIG_DIR=C:\Users\ASUS\Desktop\instantclient_19_28\network\admin

# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=your_postgres_db

# MySQL connection settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_db
